base: origin/dev
mode: full
engine: auto
review_depth: thorough
max_findings: 12
product_profile:
  name: WPManageNinja Product
  text_domain: your-text-domain
  tags:
    - payments
    - pdf-output
  focus:
    - key product workflow 1
    - key product workflow 2
  regression_checks:
    - product-specific regression expectation 1
    - product-specific regression expectation 2
focus_areas:
  - security
  - payments
  - regression
  - compatibility
paths:
  ignore:
    - public/mix-manifest.json
    - dist/**
    - vendor/**
    - builds/**
  high_risk:
    - src/Payments/**
    - src/Integrations/**
    - src/classes/**
    - app/Http/**
    - app/Services/**
notes:
  - Payment path changes should include verification for strict and non-strict flows.
  - Webhook changes should be reviewed with verification and replay risks in mind.
  - Settings or meta shape changes should be checked for backward compatibility.
accessibility:
  urls: []
  wait_for:
  timeout_ms: 30000
  storage_state:
codex:
  timeout_ms: 900000
semgrep:
  enabled: true
  config: auto
  timeout_ms: 120000
phpstan:
  enabled: true
  config: auto
  timeout_ms: 120000
eslint:
  enabled: true
  config: auto
  timeout_ms: 120000
reviewdog:
  report:
